# OpenRouter API (required for content generation & deep research)
OPENROUTER_API_KEY=sk-or-v1-xxxx

# reurl.cc short URL (optional; if not set, original LINE URL is used)
REURL_API_KEY=

# Threads API (optional; for auto-posting)
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# Deep Research (optional; uses Perplexity Sonar Pro via OpenRouter)
# No extra API key needed — uses the same OPENROUTER_API_KEY above.
# Use --research flag (CLI) or research: true (API) to enable.

# Google Sheets 紀錄（可選，未設定時靜默略過）
# 1. 建 service account 並下載 JSON key，填絕對路徑（支援 ~）
# 2. 建 Sheet，把 SA email 分享為編輯者，複製網址 /d/ 後的 ID
# 3. Tab 名預設 "Sheet1"，用其他名字就改
GOOGLE_SHEETS_SA_JSON_PATH=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB_NAME=Sheet1
