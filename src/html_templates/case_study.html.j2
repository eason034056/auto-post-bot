{% extends "base.html.j2" %}

{% block extra_style %}
  /* ── case_study：實際案例頁 ──────────────────────────────── */
  .slide-case .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding-top: 48px;
  }

  .slide-case .title {
    font-size: 52px;
    font-weight: 900;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 56px;
    white-space: pre-line;
  }

  /* 💡 用 hairline 垂直分隔三段，取代舊版的卡片容器，
         視覺更精練，「編輯設計」而非「介面設計」 */
  .slide-case .section {
    padding: 28px 0;
    border-top: 1px solid var(--hairline);
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 32px;
    align-items: baseline;
  }
  .slide-case .section:last-child {
    border-bottom: 1px solid var(--hairline);
  }
  .slide-case .section .label {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--accent);
    text-transform: uppercase;
  }
  .slide-case .section .body {
    font-size: 28px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--ink-soft);
    white-space: pre-line;
  }
{% endblock %}

{% block content %}
<div class="slide slide-case">
  <div class="eyebrow">{{ tag if tag else "實際案例 / CASE STUDY" }}</div>

  <div class="main">
    {% if title %}<h2 class="title">{{ title }}</h2>{% endif %}

    {% for section in sections %}
    <div class="section">
      <div class="label">{{ section.label }}</div>
      <div class="body">{{ section.content }}</div>
    </div>
    {% endfor %}
  </div>

  <div class="page-meta">
    <span class="brand">青椒老師</span>
    <span>{{ "%02d"|format(index) }} / {{ "%02d"|format(total) }}</span>
  </div>
</div>
{% endblock %}
